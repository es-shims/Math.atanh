{
	"name": "math.atanh",
	"version": "1.0.2",
	"description": "An ES-spec-compliant Math.atanh shim/polyfill/replacement that works as far down as ES3",
	"main": "index.js",
	"exports": {
		".": "./index.js",
		"./auto": "./auto.js",
		"./polyfill": "./polyfill.js",
		"./implementation": "./implementation.js",
		"./shim": "./shim.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"prepublishOnly": "safe-publish-latest",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"pretest": "npm run lint",
		"lint": "eslint --ext=js,mjs .",
		"postlint": "es-shim-api --bound",
		"tests-only": "nyc tape 'test/**/*.js'",
		"test": "npm run tests-only",
		"posttest": "npx npm@\">= 10.2\" audit --production",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/es-shims/Math.atanh.git"
	},
	"keywords": [
		"Math",
		"atanh",
		"Math.atanh",
		"shim",
		"polyfill",
		"es-shim",
		"API"
	],
	"author": "Nicolò Ribaudo <nicolo.ribaudo@gmail.com>",
	"funding": {
		"url": "https://github.com/es-shims/Math.atanh?sponsor=1"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/es-shims/Math.atanh/issues"
	},
	"homepage": "https://github.com/es-shims/Math.atanh#readme",
	"devDependencies": {
		"@es-shims/api": "^2.5.1",
		"@ljharb/eslint-config": "^22.2.0",
		"auto-changelog": "^2.5.0",
		"encoding": "^0.1.13",
		"eslint": "^8.57.1",
		"functions-have-names": "^1.2.3",
		"has-strict-mode": "^1.1.0",
		"in-publish": "^2.0.1",
		"npmignore": "^0.3.5",
		"nyc": "^10.3.2",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.9.0"
	},
	"dependencies": {
		"call-bind": "^1.0.8",
		"define-properties": "^1.2.1",
		"is-nan": "^1.3.2",
		"math.log1p": "^1.0.6"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".github/workflows"
		]
	},
	"engines": {
		"node": ">= 0.4"
	}
}
